# API Keys for tk-vn-product-sheet-skill
# Copy this file to .env and fill in your keys.
# .env is gitignored — your keys stay local.

# Primary image generation: Doubao Seedream 5.0 via Volcengine Ark (2K, best quality)
# Get from: https://console.volcengine.com/ark
ARK_API_KEY=""

# Fallback image generation: GPT-Image-2 via hfsyapi (1K)
# Get from: https://www.hfsyapi.cn
HFSY_API_KEY=""

# Vision pre-screening: Agnes 2.0 flash (classifies images by URL)
# Get from: https://apihub.agnes-ai.com
AGNES_API_KEY=""
